NEXT_PUBLIC_API_URL=http://localhost:4000

# Slug of the clinic /items and /items/[id] fall back to when the URL has no
# ?clinic= query param (e.g. for assignment grading, which won't know the slug convention)
NEXT_PUBLIC_DEFAULT_CLINIC_SLUG=

# Stripe test-mode publishable key (safe to expose to the browser)
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
