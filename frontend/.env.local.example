NEXT_PUBLIC_API_URL=http://localhost:4000

# Slug of the clinic /, /items, and /items/[id] fall back to when the URL has
# no ?clinic= query param and the visitor isn't logged in. Set to the seeded
# assignment demo clinic (see `npm run seed:demo` in backend/) so grading
# never depends on knowing a clinic's slug ahead of time. If left blank, the
# app still falls back to this same "dentflow-demo" slug as a last resort -
# see frontend/src/lib/publicClinic.ts.
NEXT_PUBLIC_DEFAULT_CLINIC_SLUG=dentflow-demo

# Stripe test-mode publishable key (safe to expose to the browser)
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
