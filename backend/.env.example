NODE_ENV=development
PORT=4000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dentflow?retryWrites=true&w=majority

# Frontend origin allowed to call this API. Exactly one origin is supported
# (passed straight to the `cors` package's `origin` option) - it must be the
# single deployed frontend URL in production, e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stripe test-mode secret key (backend-only, never expose to the frontend)
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
